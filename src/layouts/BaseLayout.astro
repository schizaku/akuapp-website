---
import "../styles/global.css";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import SocialDock from "@/components/SocialDock.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "AkuAPPs - Independent Mobile Apps",
  description = "AkuAPPs is an independent mobile app portfolio with utilities, lifestyle apps, and small mobile games."
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/assets/brand/akuapps-logo.jpeg" />
    <title>{title}</title>
  </head>
  <body class="bg-zinc-950 text-zinc-100 antialiased">
    <div class="min-h-screen overflow-hidden">
      <Nav />
      <SocialDock />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
