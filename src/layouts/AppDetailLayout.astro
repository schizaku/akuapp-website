---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Icon from "@/components/Icon.astro";
import PageNavigator from "@/components/PageNavigator.astro";
import ScreenshotGallery from "@/components/ScreenshotGallery.astro";
import StoreButtons from "@/components/StoreButtons.astro";
import type { AppInfo } from "@/data/apps";

interface Props {
  app: AppInfo;
}

const { app } = Astro.props;

const pageNavItems = [
  { label: "Screenshots", href: "#screenshots" },
  { label: "Features", href: "#features" },
  { label: "Description", href: "#description" }
];

const appSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: app.name,
  applicationCategory: app.category === "Game" ? "GameApplication" : "MobileApplication",
  operatingSystem: "iOS, Android",
  description: app.shortDescription,
  image: new URL(app.icon, Astro.site).toString(),
  screenshot: app.screenshots.map((screenshot) => new URL(screenshot, Astro.site).toString()),
  publisher: {
    "@type": "Organization",
    name: "AkuAPPs",
    url: new URL("/", Astro.site).toString(),
    logo: new URL("/assets/brand/akuapps-logo.jpeg", Astro.site).toString()
  },
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD"
  }
};
---

<BaseLayout
  title={`${app.name} - AkuAPPs`}
  description={app.shortDescription}
  image={app.featureGraphic ?? app.icon}
  schema={appSchema}
>
  <section class="mx-auto max-w-6xl px-4 pb-16 pt-10 sm:px-6 lg:px-8 lg:pb-20 lg:pt-14">
    <div class="overflow-hidden rounded-lg border border-white/10 bg-white/[0.045] shadow-2xl shadow-black/30">
      <div class={`h-2 bg-gradient-to-r ${app.accent}`}></div>

      {app.featureGraphic ? (
        <img
          src={app.featureGraphic}
          alt={`${app.name} feature graphic`}
          class="aspect-[1024/500] w-full bg-white object-cover"
        />
      ) : (
        <div class={`grid aspect-[1024/500] place-items-center bg-gradient-to-br ${app.accent} p-8`}>
          <img
            src={app.icon}
            alt={`${app.name} app icon placeholder`}
            class="h-28 w-28 rounded-2xl border border-white/30 object-cover shadow-2xl shadow-black/25 sm:h-36 sm:w-36"
          />
        </div>
      )}

      <div class="grid gap-6 p-5 sm:p-6 lg:grid-cols-[1fr_auto] lg:items-center lg:p-8">
        <div class="flex min-w-0 items-center gap-4 sm:gap-5">
          <img
            src={app.icon}
            alt={`${app.name} app icon placeholder`}
            class="h-20 w-20 shrink-0 rounded-2xl border border-white/10 object-cover shadow-glow sm:h-24 sm:w-24"
          />
          <div class="min-w-0">
            <p class="inline-flex rounded-full border border-white/10 bg-white/5 px-3 py-1 text-sm font-medium text-zinc-300">
              {app.category}
            </p>
            <h1 class="mt-3 text-3xl font-black tracking-normal text-white sm:text-5xl">{app.name}</h1>
            <p class="mt-3 max-w-2xl text-base leading-7 text-zinc-300 sm:text-lg">{app.tagline}</p>
          </div>
        </div>
        <div class="lg:justify-self-end">
          <StoreButtons appStore={app.appStore} googlePlay={app.googlePlay} />
        </div>
      </div>
    </div>
  </section>

  <PageNavigator items={pageNavItems} />

  <section id="screenshots" class="mx-auto max-w-6xl scroll-mt-32 px-4 py-12 sm:px-6 lg:px-8">
    <div class="mb-6 flex items-end justify-between gap-4">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-teal-200">Screenshots</p>
        <h2 class="mt-2 text-3xl font-bold text-white">A quick look inside</h2>
      </div>
    </div>
    <ScreenshotGallery screenshots={app.screenshots} appName={app.name} />
  </section>

  <section id="features" class="mx-auto max-w-6xl scroll-mt-32 px-4 py-12 sm:px-6 lg:px-8">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-teal-200">Features</p>
    <h2 class="mt-2 text-3xl font-bold text-white">Built around the core loop</h2>
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {app.features.map((feature) => (
        <article class="rounded-lg border border-white/10 bg-white/[0.045] p-5">
          <div class="grid h-11 w-11 place-items-center rounded-lg bg-white text-zinc-950">
            <Icon name={feature.icon} />
          </div>
          <h3 class="mt-5 text-lg font-semibold text-white">{feature.title}</h3>
          <p class="mt-3 text-sm leading-6 text-zinc-400">{feature.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="description" class="mx-auto max-w-3xl scroll-mt-32 px-4 py-12 sm:px-6 lg:px-8">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-teal-200">Description</p>
    <div class="mt-5 space-y-5 text-base leading-8 text-zinc-300">
      {app.description.map((paragraph) => <p>{paragraph}</p>)}
    </div>
    <a class="mt-10 inline-flex text-sm font-medium text-zinc-400 transition hover:text-white" href={`/privacy/${app.slug}`}>
      Read privacy policy
    </a>
  </section>
</BaseLayout>
