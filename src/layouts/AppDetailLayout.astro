---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Icon from "@/components/Icon.astro";
import ScreenshotGallery from "@/components/ScreenshotGallery.astro";
import StoreButtons from "@/components/StoreButtons.astro";
import type { AppInfo } from "@/data/apps";

interface Props {
  app: AppInfo;
}

const { app } = Astro.props;
---

<BaseLayout title={`${app.name} - Aku Apps`} description={app.shortDescription}>
  <section class="mx-auto grid max-w-6xl gap-12 px-4 pb-16 pt-12 sm:px-6 lg:grid-cols-[0.92fr_1.08fr] lg:px-8 lg:pb-20 lg:pt-16">
    <div class="flex items-start gap-5 lg:block">
      <img
        src={app.icon}
        alt={`${app.name} app icon placeholder`}
        class="h-24 w-24 rounded-2xl border border-white/10 object-cover shadow-glow sm:h-28 sm:w-28 lg:h-36 lg:w-36"
      />
      <div class="lg:mt-8">
        <p class="inline-flex rounded-full border border-white/10 bg-white/5 px-3 py-1 text-sm font-medium text-zinc-300">
          {app.category}
        </p>
        <h1 class="mt-4 max-w-3xl text-4xl font-black tracking-normal text-white sm:text-6xl">{app.name}</h1>
        <p class="mt-5 max-w-xl text-lg leading-8 text-zinc-300">{app.tagline}</p>
        <div class="mt-7">
          <StoreButtons appStore={app.appStore} googlePlay={app.googlePlay} />
        </div>
      </div>
    </div>
    <div class="relative min-h-96 overflow-hidden rounded-lg border border-white/10 bg-white/[0.045] p-4 shadow-2xl shadow-black/30">
      <div class={`absolute inset-x-0 top-0 h-2 bg-gradient-to-r ${app.accent}`}></div>
      <div class="grid h-full place-items-center">
        <img
          src={app.screenshots[0]}
          alt={`${app.name} primary screenshot placeholder`}
          class="aspect-[9/16] h-[34rem] max-h-[68vh] rounded-lg border border-white/10 object-cover"
        />
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="mb-6 flex items-end justify-between gap-4">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-teal-200">Screenshots</p>
        <h2 class="mt-2 text-3xl font-bold text-white">A quick look inside</h2>
      </div>
    </div>
    <ScreenshotGallery screenshots={app.screenshots} appName={app.name} />
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-teal-200">Features</p>
    <h2 class="mt-2 text-3xl font-bold text-white">Built around the core loop</h2>
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {app.features.map((feature) => (
        <article class="rounded-lg border border-white/10 bg-white/[0.045] p-5">
          <div class="grid h-11 w-11 place-items-center rounded-lg bg-white text-zinc-950">
            <Icon name={feature.icon} />
          </div>
          <h3 class="mt-5 text-lg font-semibold text-white">{feature.title}</h3>
          <p class="mt-3 text-sm leading-6 text-zinc-400">{feature.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-teal-200">Description</p>
    <div class="mt-5 space-y-5 text-base leading-8 text-zinc-300">
      {app.description.map((paragraph) => <p>{paragraph}</p>)}
    </div>
    <a class="mt-10 inline-flex text-sm font-medium text-zinc-400 transition hover:text-white" href={`/privacy/${app.slug}`}>
      Read privacy policy
    </a>
  </section>
</BaseLayout>
