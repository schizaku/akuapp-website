---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AppCard from "@/components/AppCard.astro";
import { apps } from "@/data/apps";

const homeSchema = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "AkuAPPs",
    url: "https://akuapps.com/",
    logo: "https://akuapps.com/assets/brand/akuapps-logo.jpeg",
    sameAs: [
      "https://www.youtube.com/@Aku-APPs",
      "https://www.tiktok.com/@aku.apps",
      "https://www.instagram.com/aku.apps",
      "https://apps.apple.com/tr/developer/aykut-yilmaz/id1867122375",
      "https://play.google.com/store/apps/developer?id=Aku+APPs&hl=tr"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "AkuAPPs",
    url: "https://akuapps.com/",
    description:
      "Independent mobile apps, utilities, lifestyle tools, and compact mobile games from AkuAPPs."
  }
];
---

<BaseLayout
  title="AkuAPPs - Mobile Apps, Games, Utilities and Lifestyle Tools"
  description="Discover AkuAPPs mobile apps including Secure QR Scanner, Driftombie, Love Cards, Drinkly, and Cosmic Energy."
  image="/assets/brand/akuapps-logo.jpeg"
  schema={homeSchema}
>
  <section class="mx-auto grid max-w-6xl gap-10 px-4 pb-14 pt-14 sm:px-6 lg:grid-cols-[1.02fr_0.98fr] lg:px-8 lg:pb-20 lg:pt-20">
    <div class="flex flex-col justify-center">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-teal-200">AkuAPPs</p>
      <h1 class="mt-4 max-w-3xl text-5xl font-black tracking-normal text-white sm:text-6xl lg:text-7xl">
        We are AkuAPPs - an independent mobile app studio
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-zinc-300">
        We design and publish focused mobile utilities, lifestyle tools, and compact games. Our goal is simple:
        build apps that feel useful, playful, and personal while staying clear, lightweight, and easy to trust.
      </p>
      <div class="mt-8 flex flex-col gap-3 min-[420px]:flex-row">
        <a href="#apps" class="inline-flex justify-center rounded-md bg-white px-5 py-3 text-sm font-semibold text-zinc-950 transition hover:bg-teal-200">
          Browse Apps
        </a>
        <a href="/coming-soon" class="inline-flex justify-center rounded-md border border-white/15 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/10">
          Coming Soon
        </a>
      </div>
    </div>
    <div class="grid min-h-[30rem] grid-cols-2 gap-4 sm:grid-cols-3 lg:min-h-[36rem]">
      {apps.map((app, index) => (
        <a
          href={`/apps/${app.slug}`}
          class:list={[
            "group overflow-hidden rounded-lg border border-white/10 bg-white/[0.045] p-3 transition hover:-translate-y-1 hover:border-white/20",
            index % 2 === 0 ? "self-start" : "self-end"
          ]}
        >
          <img src={app.icon} alt={`${app.name} app icon placeholder`} class="aspect-square w-full rounded-lg object-cover" />
          <p class="mt-3 truncate text-sm font-semibold text-white">{app.name}</p>
          <p class="text-xs text-zinc-500">{app.category}</p>
        </a>
      ))}
    </div>
  </section>

  <section id="apps" class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-teal-200">Apps</p>
      <h2 class="mt-2 text-3xl font-bold text-white sm:text-4xl">Small apps with a clear job</h2>
      <p class="mt-4 text-base leading-7 text-zinc-400">
        Each app has its own page, store links, screenshots, features, and privacy policy route ready for publishing.
      </p>
    </div>
    <div class="mt-9 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {apps.map((app) => <AppCard app={app} />)}
    </div>
  </section>
</BaseLayout>
