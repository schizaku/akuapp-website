---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AppCard from "@/components/AppCard.astro";
import { apps } from "@/data/apps";

const appsSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "AkuAPPs Mobile Apps",
  url: "https://akuapps.com/apps/",
  description: "Browse AkuAPPs mobile games, utilities, and lifestyle apps.",
  hasPart: apps.map((app) => ({
    "@type": "SoftwareApplication",
    name: app.name,
    applicationCategory: app.category === "Game" ? "GameApplication" : "MobileApplication",
    url: `https://akuapps.com/apps/${app.slug}/`,
    description: app.shortDescription,
    image: `https://akuapps.com${app.icon}`
  }))
};
---

<BaseLayout
  title="AkuAPPs Apps - Mobile Games, Utilities and Lifestyle Tools"
  description="Browse all AkuAPPs mobile apps including Secure QR Scanner, Driftombie, Love Cards, Drinkly, and Cosmic Energy."
  image="/assets/brand/akuapps-logo.jpeg"
  schema={appsSchema}
>
  <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8 lg:py-20">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-teal-200">Apps</p>
    <h1 class="mt-4 max-w-3xl text-5xl font-black tracking-normal text-white sm:text-6xl">
      AkuAPPs mobile apps
    </h1>
    <p class="mt-6 max-w-2xl text-lg leading-8 text-zinc-300">
      Explore our mobile utilities, lifestyle tools, and compact games. Each app page includes screenshots,
      features, store links, and privacy details.
    </p>
    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {apps.map((app) => <AppCard app={app} />)}
    </div>
  </section>
</BaseLayout>
