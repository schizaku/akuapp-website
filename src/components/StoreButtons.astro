---
import type { StoreLink } from "@/data/apps";

interface Props {
  appStore: StoreLink;
  googlePlay: StoreLink;
}

const { appStore, googlePlay } = Astro.props;
---

<div class="flex flex-col gap-3 min-[420px]:flex-row">
  <a
    href={appStore.href}
    class="inline-flex min-h-14 items-center justify-center rounded-lg bg-black px-5 py-3 text-left text-white ring-1 ring-white/15 transition hover:-translate-y-0.5 hover:ring-white/30"
  >
    <span class="mr-3 text-2xl leading-none">A</span>
    <span>
      <span class="block text-[0.68rem] uppercase leading-none text-zinc-300">Download on the</span>
      <span class="mt-1 block text-base font-semibold leading-none">{appStore.label}</span>
    </span>
  </a>
  <a
    href={googlePlay.href}
    class="inline-flex min-h-14 items-center justify-center rounded-lg bg-zinc-900 px-5 py-3 text-left text-white ring-1 ring-white/15 transition hover:-translate-y-0.5 hover:ring-white/30"
  >
    <span class="mr-3 text-2xl leading-none">G</span>
    <span>
      <span class="block text-[0.68rem] uppercase leading-none text-zinc-300">Get it on</span>
      <span class="mt-1 block text-base font-semibold leading-none">{googlePlay.label}</span>
    </span>
  </a>
</div>
