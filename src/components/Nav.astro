---
import LanguageSelector from "@/components/LanguageSelector.astro";

const links = [
  { label: "Apps", href: "/apps" },
  { label: "Testers Club", href: "/testers-club" }
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-zinc-950/78 backdrop-blur-xl">
  <nav class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-3 py-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <a href="/" class="group inline-flex items-center gap-3">
      <img
        src="/assets/brand/akuapps-logo.jpeg"
        alt="AkuAPPs logo"
        class="h-10 w-10 rounded-lg border border-white/10 object-cover shadow-glow"
      />
      <span class="hidden text-base font-semibold tracking-normal text-white min-[480px]:inline">AkuAPPs</span>
    </a>
    <div class="flex min-w-0 items-center gap-1 sm:gap-2">
      {links.map((link) => (
        <a
          href={link.href}
          class="rounded-md px-2 py-2 text-sm font-medium text-zinc-300 transition hover:bg-white/10 hover:text-white sm:px-3"
        >
          {link.label}
        </a>
      ))}
      <LanguageSelector />
      <a
        href="mailto:hello@akuapps.com"
        class="rounded-md px-2 py-2 text-sm font-medium text-zinc-300 transition hover:bg-white/10 hover:text-white sm:px-3"
      >
        Contact
      </a>
    </div>
  </nav>
</header>
