---
const links = [
  { label: "Apps", href: "/#apps" },
  { label: "Contact", href: "mailto:hello@akuapps.com" }
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-zinc-950/78 backdrop-blur-xl">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <a href="/" class="group inline-flex items-center gap-3">
      <span class="grid h-10 w-10 place-items-center rounded-lg bg-white text-sm font-black text-zinc-950 shadow-glow">
        A
      </span>
      <span class="text-base font-semibold tracking-normal text-white">Aku Apps</span>
    </a>
    <div class="flex items-center gap-2">
      {links.map((link) => (
        <a
          href={link.href}
          class="rounded-md px-3 py-2 text-sm font-medium text-zinc-300 transition hover:bg-white/10 hover:text-white"
        >
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>
