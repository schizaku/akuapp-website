---
type NavItem = {
  label: string;
  href: string;
};

interface Props {
  items: NavItem[];
}

const { items } = Astro.props;
---

<nav
  class="fixed bottom-4 right-4 z-40 w-44 rounded-lg border border-white/10 bg-zinc-950/88 p-3 shadow-2xl shadow-black/40 backdrop-blur-xl sm:bottom-auto sm:right-5 sm:top-28 lg:right-8"
  aria-label="Page navigation"
>
  <span class="block text-[0.65rem] font-semibold uppercase leading-4 tracking-[0.16em] text-zinc-500">
    Page Navigator
  </span>
  <div class="mt-3 grid gap-2">
    {items.map((item) => (
      <a
        href={item.href}
        class="rounded-md border border-white/10 bg-white/[0.045] px-3 py-2 text-sm font-medium text-zinc-300 transition hover:border-white/20 hover:bg-white/10 hover:text-white"
      >
        {item.label}
      </a>
    ))}
  </div>
</nav>
