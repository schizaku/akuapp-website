---
type NavItem = {
  label: string;
  href: string;
};

interface Props {
  items: NavItem[];
}

const { items } = Astro.props;
---

<nav class="sticky top-[4.5rem] z-40 border-y border-white/10 bg-zinc-950/82 backdrop-blur-xl" aria-label="Page navigation">
  <div class="mx-auto flex max-w-6xl items-center gap-3 overflow-x-auto px-4 py-3 sm:px-6 lg:px-8">
    <span class="shrink-0 text-xs font-semibold uppercase tracking-[0.16em] text-zinc-500">Page Navigator</span>
    <div class="flex min-w-max items-center gap-2">
      {items.map((item) => (
        <a
          href={item.href}
          class="rounded-md border border-white/10 bg-white/[0.045] px-3 py-2 text-sm font-medium text-zinc-300 transition hover:border-white/20 hover:bg-white/10 hover:text-white"
        >
          {item.label}
        </a>
      ))}
    </div>
  </div>
</nav>
