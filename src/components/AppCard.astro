---
import type { AppInfo } from "@/data/apps";

interface Props {
  app: AppInfo;
}

const { app } = Astro.props;
---

<article class="group flex h-full flex-col overflow-hidden rounded-lg border border-white/10 bg-white/[0.045] transition hover:-translate-y-1 hover:border-white/20 hover:bg-white/[0.07]">
  <a href={`/apps/${app.slug}`} class="block">
    <div class={`h-2 bg-gradient-to-r ${app.accent}`}></div>
    <div class="p-5">
      <div class="flex items-start gap-4">
        <img
          src={app.icon}
          alt={`${app.name} app icon placeholder`}
          class="h-16 w-16 rounded-xl border border-white/10 object-cover"
          loading="lazy"
        />
        <div class="min-w-0">
          <p class="inline-flex rounded-full border border-white/10 bg-white/5 px-2.5 py-1 text-xs font-medium text-zinc-300">
            {app.category}
          </p>
          <h2 class="mt-3 text-xl font-semibold text-white">{app.name}</h2>
        </div>
      </div>
      <p class="mt-4 min-h-20 text-sm leading-6 text-zinc-400">{app.shortDescription}</p>
      <span class="mt-5 inline-flex rounded-md bg-white px-4 py-2 text-sm font-semibold text-zinc-950 transition group-hover:bg-teal-200">
        View App
      </span>
    </div>
  </a>
</article>
