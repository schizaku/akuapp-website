---
import { socialLinks, storeProfileLinks } from "@/data/socialLinks";
import type { SocialLink, StoreProfileLink } from "@/data/socialLinks";

const iconPaths: Record<SocialLink["label"], string> = {
  YouTube:
    '<path d="M21.6 7.1a2.8 2.8 0 0 0-2-2C17.8 4.6 12 4.6 12 4.6s-5.8 0-7.6.5a2.8 2.8 0 0 0-2 2A29 29 0 0 0 2 12a29 29 0 0 0 .4 4.9 2.8 2.8 0 0 0 2 2c1.8.5 7.6.5 7.6.5s5.8 0 7.6-.5a2.8 2.8 0 0 0 2-2A29 29 0 0 0 22 12a29 29 0 0 0-.4-4.9Z"/><path fill="#09090b" d="m10 15.5 5.2-3.5L10 8.5v7Z"/>',
  TikTok:
    '<path d="M16.8 3c.3 2.5 1.7 4 4.2 4.2v4.1a8 8 0 0 1-4.1-1.2v5.9c0 3.1-2.5 5.7-5.7 5.7a5.7 5.7 0 1 1 0-11.4c.4 0 .8 0 1.1.1v4.2a1.7 1.7 0 0 0-1.1-.3 1.7 1.7 0 1 0 1.7 1.7V3h3.9Z"/>',
  Instagram:
    '<rect x="4" y="4" width="16" height="16" rx="4.5"/><circle cx="12" cy="12" r="3.2" fill="#09090b"/><circle cx="16.9" cy="7.1" r="1.1" fill="#09090b"/>'
};

const storeIconPaths: Record<StoreProfileLink["label"], string> = {
  "App Store":
    '<path d="M17.05 12.55c-.02-2.18 1.78-3.23 1.86-3.28-1.02-1.49-2.6-1.7-3.15-1.72-1.33-.14-2.62.79-3.3.79-.69 0-1.73-.77-2.85-.75-1.46.02-2.82.85-3.57 2.16-1.54 2.66-.39 6.57 1.09 8.72.74 1.06 1.6 2.24 2.73 2.2 1.1-.04 1.51-.7 2.84-.7 1.31 0 1.69.7 2.85.68 1.18-.02 1.93-1.06 2.64-2.13.85-1.22 1.19-2.43 1.2-2.49-.03-.01-2.31-.89-2.34-3.48Z"/><path d="M14.9 6.15c.6-.73 1.01-1.73.9-2.75-.87.04-1.96.6-2.59 1.32-.56.65-1.06 1.69-.93 2.68.98.08 1.99-.5 2.62-1.25Z"/>',
  "Google Play":
    '<path d="M5.4 3.9c-.38.4-.6 1-.6 1.76v20.68c0 .76.22 1.36.62 1.76l.08.08L17.1 16.16v-.32L5.48 3.82l-.08.08Z" fill="#00f0ff"/><path d="m20.96 20.18-3.86-4.02v-.32l3.87-4.02.08.05 4.58 2.6c1.31.75 1.31 1.98 0 2.73l-4.58 2.61-.09.37Z" fill="#ffd400"/><path d="m21.05 19.81-3.95-3.97L5.4 28.1c.6.64 1.58.72 2.69.09l12.96-8.38Z" fill="#ff3d62"/><path d="M21.05 11.87 8.09 3.49C6.98 2.86 6 2.94 5.4 3.58l11.7 12.26 3.95-3.97Z" fill="#00d084"/>'
};
---

<aside
  class="fixed bottom-4 left-4 z-40 w-16 rounded-lg border border-white/10 bg-zinc-950/88 p-2 shadow-2xl shadow-black/40 backdrop-blur-xl sm:bottom-auto sm:top-1/2 sm:-translate-y-1/2 lg:left-8"
  aria-label="AkuAPPs social links"
>
  <div class="grid gap-2">
    {socialLinks.map((link) => (
      <a
        href={link.href}
        aria-label={`AkuAPPs on ${link.label}`}
        title={link.label}
        class="grid h-12 w-12 place-items-center rounded-md border border-white/10 bg-white/[0.045] text-white transition hover:border-white/20 hover:bg-white hover:text-zinc-950"
        target={link.href === "#" ? undefined : "_blank"}
        rel={link.href === "#" ? undefined : "noreferrer"}
      >
        <svg
          class="h-6 w-6"
          viewBox="0 0 24 24"
          aria-hidden="true"
          fill="currentColor"
        >
          <Fragment set:html={iconPaths[link.label]} />
        </svg>
      </a>
    ))}
    <div class="my-1 h-px bg-white/10"></div>
    {storeProfileLinks.map((link) => (
      <a
        href={link.href}
        aria-label={`AkuAPPs on ${link.label}`}
        title={link.label}
        class="grid h-12 w-12 place-items-center rounded-md border border-white/10 bg-white/[0.045] text-white transition hover:border-white/20 hover:bg-white hover:text-zinc-950"
        target="_blank"
        rel="noreferrer"
      >
        <svg
          class="h-6 w-6"
          viewBox={link.label === "Google Play" ? "0 0 32 32" : "0 0 24 24"}
          aria-hidden="true"
          fill="currentColor"
        >
          <Fragment set:html={storeIconPaths[link.label]} />
        </svg>
      </a>
    ))}
  </div>
</aside>
