---
interface Props {
  screenshots: string[];
  appName: string;
}

const { screenshots, appName } = Astro.props;
---

<div class="scrollbar-soft -mx-4 flex gap-4 overflow-x-auto px-4 pb-5 sm:-mx-6 sm:px-6 lg:mx-0 lg:px-0">
  {screenshots.map((screenshot, index) => (
    <img
      src={screenshot}
      alt={`${appName} screenshot placeholder ${index + 1}`}
      class="aspect-[9/16] w-52 shrink-0 rounded-lg border border-white/10 bg-zinc-900 object-cover shadow-2xl shadow-black/30 sm:w-60"
      loading="lazy"
    />
  ))}
</div>
